# Copia in .env e cambia le password in produzione. Valori di default = solo sviluppo locale.
# .env è la fonte unica di configurazione: viene letto sia da `docker compose`
# (automaticamente) sia dal processo Python (caricato da config.py all'import,
# vedi backend/src/bussola/data/config.py), così i due restano sempre allineati.
POSTGRES_SUPERUSER_PASSWORD=postgres_dev
BUSSOLA_OWNER_PASSWORD=owner_dev
BUSSOLA_APP_PASSWORD=app_dev
BUSSOLA_AUDITOR_PASSWORD=auditor_dev
# Connessione (default già validi per docker-compose locale)
BUSSOLA_DB_HOST=127.0.0.1
BUSSOLA_DB_PORT=5432
BUSSOLA_DB_NAME=bussola
# LLM locale (llama-server, OpenAI-compatibile)
BUSSOLA_LLM_BASE_URL=http://127.0.0.1:8080
BUSSOLA_LLM_MODEL=qwen2.5-7b-instruct
BUSSOLA_LLM_TIMEOUT=120
# Porta su cui scripts/serve-llm.sh avvia llama-server (deve combaciare con BUSSOLA_LLM_BASE_URL)
BUSSOLA_LLM_PORT=8080
